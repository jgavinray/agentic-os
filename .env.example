# Database
DATABASE_URL=postgresql://agent:agentpass@postgres:5432/agentstack

# Vector memory
QDRANT_URL=http://qdrant:6333

# Local models mounted into the orchestrator container
EMBED_MODEL_PATH=/data/models/embed
SENTIMENT_MODEL_PATH=/data/models/sentiment
SENTIMENT_THRESHOLD=0.70

# LiteLLM
LITELLM_URL=http://litellm:4000/v1
LITELLM_KEY=sk-local-agentstack
LITELLM_SALT_KEY=  # generate with: openssl rand -hex 32

# API keys for orchestrator endpoints — comma-separated for multi-namespace support.
# Each key becomes a memory namespace: sk-work → repo=work, sk-home → repo=home.
# Clients only need to set their base URL and API key — no custom headers required.
API_KEYS=sk-local-orchestrator

# Default model and task for completions
DEFAULT_MODEL=qwen36-35b-heretic
DEFAULT_TASK=engineering

# Context optimization
CONTEXT_CACHE_TTL_MS=300000
CONTEXT_DECAY_RATE=0.006
EXECUTION_FEEDBACK_ENABLED=true
TRAJECTORY_CAPTURE_ENABLED=true
TRAJECTORY_IDLE_TIMEOUT_SEC=600
FAILURE_HISTORY_TOKEN_BUDGET=1000
SAMPLING_CAPTURE_ENABLED=true
SAMPLING_OVERRIDE_ENABLED=false

# Inference route rate limiting, per API key
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=30

# Browser CORS policy. "*" preserves the local-node default; use a comma-separated
# origin list before exposing the orchestrator beyond localhost/Tailscale.
ALLOWED_ORIGINS=*

# Optional OTLP tracing endpoint when built with the tracing-otlp feature
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
